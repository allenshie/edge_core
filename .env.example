# Sample environment variables for running edge/main.py locally

# Monitoring / logging
MONITOR_ENDPOINT=http://localhost:9400
EDGE_MONITOR_SERVICE_NAME=edge-cam01
EDGE_LOG_LEVEL=INFO

# Workflow scheduling / retry
EDGE_POLL_INTERVAL=5
EDGE_RETRY_BACKOFF=5

# Resource root / schedule
EDGE_RESOURCE_ROOT=.
EDGE_SCHEDULE_PATH=./schedules/schedule.json

# Ingestion source (switch EDGE_INGEST_MODE between rtsp/file)
EDGE_CAMERA_ID=cam01
EDGE_INGEST_MODE=rtsp
EDGE_RTSP_URL=rtsp://example-nvr.local/cam01
EDGE_FILE_PATH=./data/samples/warehouse_cam01.mp4
EDGE_FILE_LOOP=1
EDGE_FILE_FPS=15
EDGE_FILE_DROP_FRAMES=0

# RTSP tuning (only used when EDGE_INGEST_MODE=rtsp)
EDGE_RTSP_DROP_FRAMES=2
EDGE_RTSP_RECONNECT=1
EDGE_RTSP_FPS=15

# Model / inference
EDGE_MODEL_NAME=yolo11n
EDGE_MODEL_PATH=models/sample_yolo11n.pt
EDGE_MODEL_DEVICE=cpu
EDGE_CONF_THRESHOLD=0.4
EDGE_TRACKER_CONFIG=trackers/bytetrack.yaml
# INFERENCE_ENGINE_CLASS=package.module:Class
# PUBLISH_ENGINE_CLASS=package.module:Class

# Mode server / phase control
EDGE_MODE_DEFAULT=working_stage_1
EDGE_MODE_STRATEGY=external
EDGE_MODE_SERVER_ENABLED=0
EDGE_MODE_SERVER_HOST=0.0.0.0
EDGE_MODE_SERVER_PORT=9100

# MQTT mode updates (optional)
EDGE_MQTT_ENABLED=0
EDGE_MQTT_HOST=localhost
EDGE_MQTT_PORT=1883
EDGE_PHASE_MQTT_TOPIC=integration/phase
EDGE_MQTT_QOS=1

# Visualization output
EDGE_VISUAL_ENABLED=1
EDGE_VISUAL_MODE=write
EDGE_VISUAL_WINDOW=edge-preview
EDGE_VISUAL_WIDTH=1280
EDGE_VISUAL_HEIGHT=720

# Streaming output
EDGE_STREAMING_ENABLED=false
EDGE_STREAMING_URL=rtmp://127.0.0.1:1935/live/cam01
EDGE_STREAMING_STRATEGY=cpu
EDGE_STREAMING_QUEUE_SIZE=30
EDGE_STREAMING_IDLE_TIMEOUT=3
EDGE_STREAMING_RESTART_BACKOFF=1
EDGE_STREAMING_OUT_WIDTH=1280
EDGE_STREAMING_OUT_HEIGHT=720

# Integration endpoint (integration daemon)
INTEGRATION_API_BASE=http://localhost:9000
INTEGRATION_API_TIMEOUT=5
EDGE_PUBLISH_BACKEND=http
EDGE_EVENTS_MQTT_TOPIC=edge/events
